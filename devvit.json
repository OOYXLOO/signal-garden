{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "signalgardenyxl",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create daily relay post",
        "description": "Start a Signal Garden relay board",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:devvit",
    "dev": "npm run build:devvit -- --watch"
  }
}
